# StickyDesk — environment configuration (TEMPLATE)
# Copy this file to ".env" (same folder) and paste your keys. ".env" is git-ignored.
# Consumed at M5 (speech-to-text) and M8 (AI). Missing keys = those features stay disabled.

# Tip: set STT_PROVIDER=fake or AI_PROVIDER=fake to try the features offline (no key needed).

# ===== Speech-to-Text (M5) =====
STT_PROVIDER=deepgram                 # deepgram | assemblyai | fake
DEEPGRAM_API_KEY=                     # paste your Deepgram key
DEEPGRAM_MODEL=nova-3
ASSEMBLYAI_API_KEY=                   # paste your AssemblyAI key
ASSEMBLYAI_MODEL=universal

# ===== AI / Gemini (M8) =====
AI_PROVIDER=                          # vertex | gemini | fake | (blank = auto-detect from keys)
# PRIMARY: Vertex AI Express — paste your Vertex Express API key (format: AQ.Ab8...)
VERTEX_AI_API_KEY=
VERTEX_BASE_URL=https://aiplatform.googleapis.com/v1
# FALLBACK: Google AI Studio key (format: AIzaSy...) — optional
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3.5-flash

# ===== Auto-update (M10) — your GitHub repo for releases =====
GITHUB_OWNER=
GITHUB_REPO=

# ===== Google Calendar sync (V2) =====
# Create an OAuth 2.0 "Desktop app" client in Google Cloud Console (Calendar API enabled),
# then paste its credentials here to enable two-way Google Calendar sync.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
