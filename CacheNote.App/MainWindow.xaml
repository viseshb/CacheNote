<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="CacheNote_App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CacheNote_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="using:H.NotifyIcon"
    Title="CacheNote"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.KeyboardAccelerators>
            <!-- In-window new note. Ctrl+F / Ctrl+P / Ctrl+D land with search & pin in M4. -->
            <KeyboardAccelerator
                Key="N"
                Invoked="NewNoteAccelerator_Invoked"
                Modifiers="Control" />
        </Grid.KeyboardAccelerators>
        <Grid.Resources>
            <!-- Flat icon button with a clear hover/press shade (title-bar actions). -->
            <Style x:Key="TitleBarButton" TargetType="Button">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid
                                x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource AppHoverBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource AppPressedBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Title-bar toggle (always-on-top): accent fill when ON for a clear on/off state. -->
            <Style x:Key="TitleBarToggle" TargetType="ToggleButton">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Foreground" Value="{ThemeResource AppTextPrimaryBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid
                                x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver"><VisualState.Setters><Setter Target="Root.Background" Value="{ThemeResource AppHoverBrush}" /></VisualState.Setters></VisualState>
                                        <VisualState x:Name="Pressed"><VisualState.Setters><Setter Target="Root.Background" Value="{ThemeResource AppPressedBrush}" /></VisualState.Setters></VisualState>
                                        <VisualState x:Name="Checked"><VisualState.Setters><Setter Target="Root.Background" Value="{ThemeResource AppAccentBrush}" /><Setter Target="Content.Foreground" Value="White" /></VisualState.Setters></VisualState>
                                        <VisualState x:Name="CheckedPointerOver"><VisualState.Setters><Setter Target="Root.Background" Value="{ThemeResource AppAccentBrush}" /><Setter Target="Content.Foreground" Value="White" /></VisualState.Setters></VisualState>
                                        <VisualState x:Name="CheckedPressed"><VisualState.Setters><Setter Target="Root.Background" Value="{ThemeResource AppAccentBrush}" /><Setter Target="Content.Foreground" Value="White" /></VisualState.Setters></VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter x:Name="Content" HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Floating AI ball: circular, gradient, springy hover/press. -->
            <Style x:Key="AiBallStyle" TargetType="Button">
                <Setter Property="Width" Value="56" />
                <Setter Property="Height" Value="56" />
                <Setter Property="CornerRadius" Value="28" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="{ThemeResource AiBallBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{ThemeResource AiBallBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="BallScale" ScaleX="1" ScaleY="1" />
                                </Border.RenderTransform>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BallScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12" />
                                                <DoubleAnimation Storyboard.TargetName="BallScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BallScale" Storyboard.TargetProperty="ScaleX" To="1.08" Duration="0:0:0.12" />
                                                <DoubleAnimation Storyboard.TargetName="BallScale" Storyboard.TargetProperty="ScaleY" To="1.08" Duration="0:0:0.12" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BallScale" Storyboard.TargetProperty="ScaleX" To="0.92" Duration="0:0:0.08" />
                                                <DoubleAnimation Storyboard.TargetName="BallScale" Storyboard.TargetProperty="ScaleY" To="0.92" Duration="0:0:0.08" />
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Accent action button (AI Apply / Send). -->
            <Style x:Key="AiAccentButton" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource AppAccentBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>

            <!-- Dynamic-island open: scale + fade the panel up from the ball's corner; fade the ball out. -->
            <Storyboard x:Key="AiOpenStoryboard">
                <DoubleAnimation Storyboard.TargetName="AiPanelScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.22">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="AiPanelScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.22">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="AiPanel" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
                <DoubleAnimation Storyboard.TargetName="AiBall" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12" />
            </Storyboard>
            <Storyboard x:Key="AiCloseStoryboard">
                <DoubleAnimation Storyboard.TargetName="AiPanelScale" Storyboard.TargetProperty="ScaleX" To="0.2" Duration="0:0:0.16">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="AiPanelScale" Storyboard.TargetProperty="ScaleY" To="0.2" Duration="0:0:0.16">
                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="AiPanel" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.14" />
                <DoubleAnimation Storyboard.TargetName="AiBall" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" />
            </Storyboard>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>

            <!-- Left corner: always-on-top pin toggle (accent when ON). -->
            <ToggleButton
                x:Name="PinToggle"
                Grid.Column="0"
                Margin="6,0,0,0"
                AutomationProperties.AutomationId="PinToggle"
                AutomationProperties.Name="Always on top"
                Click="PinToggle_Click"
                Style="{StaticResource TitleBarToggle}"
                ToolTipService.ToolTip="Always on top">
                <FontIcon FontSize="15" Glyph="&#xE840;" />
            </ToggleButton>

            <!-- Center: drag region + app name. -->
            <Border x:Name="AppTitleBar" Grid.Column="1" Background="Transparent" />
            <TextBlock
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="{ThemeResource AppTextPrimaryBrush}"
                IsHitTestVisible="False"
                Text="CacheNote" />

            <!-- Right: update, theme, gear (left of the system caption buttons). -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <Button
                    x:Name="UpdateButton"
                    AutomationProperties.AutomationId="UpdateButton"
                    AutomationProperties.Name="Check for updates"
                    Click="Update_Click"
                    Style="{StaticResource TitleBarButton}"
                    ToolTipService.ToolTip="Check for updates">
                    <FontIcon FontSize="15" Glyph="&#xE896;" />
                </Button>
                <Button
                    x:Name="ThemeToggleButton"
                    AutomationProperties.AutomationId="ThemeToggle"
                    AutomationProperties.Name="Toggle light or dark theme"
                    Click="ThemeToggle_Click"
                    Style="{StaticResource TitleBarButton}"
                    ToolTipService.ToolTip="Toggle light / dark theme">
                    <FontIcon x:Name="ThemeIcon" FontSize="16" Glyph="&#xE706;" />
                </Button>
                <Button
                    x:Name="SettingsButton"
                    AutomationProperties.AutomationId="SettingsGear"
                    AutomationProperties.Name="Settings"
                    Click="Gear_Click"
                    Style="{StaticResource TitleBarButton}"
                    ToolTipService.ToolTip="Settings">
                    <FontIcon FontSize="15" Glyph="&#xE713;" />
                </Button>
            </StackPanel>
        </Grid>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" />

        <!-- Global AI assistant: a floating ball (bottom-right, above page content) that expands,
             dynamic-island style, into an inline chat. Available on every section. -->
        <Grid Grid.Row="1" Margin="0,0,0,0">
            <Button
                x:Name="AiBall"
                Margin="0,0,24,24"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                AutomationProperties.AutomationId="AiBall"
                AutomationProperties.Name="AI assistant"
                Click="AiBall_Click"
                Style="{StaticResource AiBallStyle}"
                ToolTipService.ToolTip="AI assistant — create notes, tasks &amp; more">
                <FontIcon FontSize="20" Foreground="{ThemeResource AiBallForegroundBrush}" Glyph="&#xE8BD;" />
            </Button>

            <Border
                x:Name="AiPanel"
                Width="360"
                MaxHeight="540"
                Margin="0,0,24,24"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                AutomationProperties.AutomationId="AiChatPanel"
                Background="{ThemeResource AppSurfaceBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                IsHitTestVisible="False"
                Opacity="0"
                RenderTransformOrigin="1,1"
                Visibility="Collapsed">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="AiPanelScale" ScaleX="0.2" ScaleY="0.2" />
                </Border.RenderTransform>

                <Grid Padding="16" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon FontSize="15" Foreground="{ThemeResource AppTextPrimaryBrush}" Glyph="&#xE8BD;" />
                            <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource AppTextPrimaryBrush}" Text="AI Assistant" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button
                            x:Name="AiClose"
                            HorizontalAlignment="Right"
                            AutomationProperties.AutomationId="AiChatClose"
                            AutomationProperties.Name="Close AI assistant"
                            Click="AiClose_Click"
                            Style="{StaticResource TitleBarButton}"
                            ToolTipService.ToolTip="Close">
                            <FontIcon FontSize="13" Glyph="&#xE711;" />
                        </Button>
                    </Grid>

                    <!-- Conversation / preview -->
                    <ScrollViewer x:Name="AiScroll" Grid.Row="1" MinHeight="120" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="8">
                            <TextBlock
                                x:Name="AiStatus"
                                AutomationProperties.AutomationId="AiStatus"
                                Foreground="{ThemeResource AppTextSecondaryBrush}"
                                Text="Ask me to create notes, tasks, reminders, calendar events, or favorites — type below or use the mic."
                                TextWrapping="Wrap" />
                            <StackPanel x:Name="AiConversation" Spacing="4" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Note-context quick actions -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="AiSummarize" AutomationProperties.AutomationId="AiSummarize" Click="AiSummarize_Click" Content="Summarize note" FontSize="12" />
                        <Button x:Name="AiRephrase" AutomationProperties.AutomationId="AiRephrase" Click="AiRephrase_Click" Content="Rephrase selection" FontSize="12" />
                    </StackPanel>

                    <!-- Input row: type or dictate -->
                    <Grid Grid.Row="3" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="AiInput"
                            Grid.Column="0"
                            MaxHeight="100"
                            AcceptsReturn="False"
                            AutomationProperties.AutomationId="AiChatInput"
                            AutomationProperties.Name="Ask AI"
                            KeyDown="AiInput_KeyDown"
                            PlaceholderText="Ask AI to do something…"
                            TextWrapping="Wrap" />
                        <ToggleButton
                            x:Name="AiMic"
                            Grid.Column="1"
                            Width="40"
                            Height="36"
                            Padding="0"
                            AutomationProperties.AutomationId="AiChatMic"
                            AutomationProperties.Name="Dictate"
                            Click="AiMic_Click"
                            ToolTipService.ToolTip="Dictate (speech to text)">
                            <FontIcon FontSize="15" Glyph="&#xE720;" />
                        </ToggleButton>
                        <Button
                            x:Name="AiSend"
                            Grid.Column="2"
                            Width="40"
                            Height="36"
                            Padding="0"
                            AutomationProperties.AutomationId="AiChatSend"
                            AutomationProperties.Name="Send"
                            Click="AiSend_Click"
                            Style="{StaticResource AiAccentButton}"
                            ToolTipService.ToolTip="Send">
                            <FontIcon FontSize="15" Foreground="White" Glyph="&#xE724;" />
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- System tray icon (renders nothing in-window). Left-click opens; right-click = menu. -->
        <tb:TaskbarIcon
            x:Name="TrayIcon"
            IconSource="/Assets/AppIcon.ico"
            ToolTipText="CacheNote — click to open">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Click="Tray_Open" Text="Open CacheNote">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8A7;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Click="Tray_NewNote" Text="New note">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE70F;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Click="Tray_NewTask" Text="New task">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8FD;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <ToggleMenuFlyoutItem x:Name="AlwaysOnTopItem" Click="Tray_ToggleAlwaysOnTop" Text="Always on top" />
                    <ToggleMenuFlyoutItem x:Name="PauseNotifyItem" Click="Tray_TogglePause" Text="Pause notifications" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Click="Tray_Settings" Text="Settings">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE713;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Click="Tray_Exit" Text="Exit">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE7E8;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>
    </Grid>
</Window>
