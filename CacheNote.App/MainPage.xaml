<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CacheNote_App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CacheNote_App.Controls"
    xmlns:conv="using:CacheNote_App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CacheNote_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:CacheNote.Core.ViewModels"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <conv:BoolToSelectionBrushConverter x:Key="SelBrush" />
        <conv:HexToBrushConverter x:Key="HexToBrush" />

        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="7,6" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{ThemeResource AppTextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource AppHoverBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource AppPressedBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="ContentHost.Opacity" Value="0.4" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter
                                x:Name="ContentHost"
                                Padding="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                Foreground="{TemplateBinding Foreground}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="7,6" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{ThemeResource AppTextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource AppHoverBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource AppPressedBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="ContentHost.Opacity" Value="0.4" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Checked">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource AppAccentBrush}" />
                                            <Setter Target="ContentHost.Foreground" Value="White" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource AppAccentBrush}" />
                                            <Setter Target="ContentHost.Foreground" Value="White" />
                                            <Setter Target="HoverOverlay.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="CheckedPressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource AppAccentBrush}" />
                                            <Setter Target="ContentHost.Foreground" Value="White" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border
                                x:Name="HoverOverlay"
                                Background="#26FFFFFF"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0" />
                            <ContentPresenter
                                x:Name="ContentHost"
                                Padding="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                Foreground="{TemplateBinding Foreground}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator
                Key="F"
                Invoked="FindAccelerator_Invoked"
                Modifiers="Control" />
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="12,8,16,4">
            <!-- Left: back-to-list (compact only) + Home + list toggle (near the list) -->
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Button
                    x:Name="BackToListButton"
                    AutomationProperties.AutomationId="BackToList"
                    AutomationProperties.Name="Back to notes list"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="BackToList_Click"
                    Style="{StaticResource ToolButton}"
                    ToolTipService.ToolTip="Back to notes"
                    Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="13" Glyph="&#xE72B;" />
                        <TextBlock FontSize="13" Text="Notes" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="HomeButton"
                    AutomationProperties.AutomationId="BackToHome"
                    AutomationProperties.Name="Back to home"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="Back_Click"
                    Style="{StaticResource ToolButton}"
                    ToolTipService.ToolTip="Home">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="13" Glyph="&#xE72B;" />
                        <TextBlock x:Name="HomeText" FontSize="13" Text="Home" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="ToggleListButton"
                    AutomationProperties.AutomationId="ToggleListButton"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="ToggleList_Click"
                    Style="{StaticResource ToolButton}"
                    ToolTipService.ToolTip="Show / hide list">
                    <FontIcon FontSize="14" Glyph="&#xE700;" />
                </Button>
            </StackPanel>

            <!-- Center: section title -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <FontIcon FontSize="16" Foreground="{ThemeResource AppAccentBrush}" Glyph="&#xE70F;" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextPrimaryBrush}"
                    Text="Notes" />
            </StackPanel>
            <StackPanel
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="2">
                <TextBlock
                    x:Name="SavedText"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{ThemeResource AppTextSecondaryBrush}"
                    Text="{x:Bind Vm.SavedStatus, Mode=OneWay}" />
                <Button
                    x:Name="RemindButton"
                    AutomationProperties.AutomationId="RemindButton"
                    AutomationProperties.Name="Set a reminder for this note"
                    Background="Transparent"
                    BorderThickness="0"
                    Style="{StaticResource ToolButton}"
                    ToolTipService.ToolTip="Remind me about this note">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="13" Glyph="&#xE823;" />
                        <TextBlock x:Name="RemindText" FontSize="13" Text="Remind" />
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout Opening="RemindFlyout_Opening" Placement="Bottom">
                            <StackPanel Width="250" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Remind me about this note" />
                                <TextBox x:Name="RemindMessage" AutomationProperties.AutomationId="RemindMessage" PlaceholderText="Message (defaults to title)" />
                                <CalendarDatePicker x:Name="RemindDate" HorizontalAlignment="Stretch" AutomationProperties.AutomationId="RemindDate" PlaceholderText="Pick a date" />
                                <TimePicker x:Name="RemindTime" HorizontalAlignment="Stretch" AutomationProperties.AutomationId="RemindTime" ClockIdentifier="12HourClock" />
                                <ComboBox x:Name="RemindRepeat" HorizontalAlignment="Stretch" AutomationProperties.AutomationId="RemindRepeat" SelectedIndex="0">
                                    <ComboBoxItem Content="Once" />
                                    <ComboBoxItem Content="Daily" />
                                    <ComboBoxItem Content="Weekly" />
                                    <ComboBoxItem Content="Monthly" />
                                </ComboBox>
                                <Button
                                    x:Name="SetReminderButton"
                                    HorizontalAlignment="Right"
                                    AutomationProperties.AutomationId="SetReminder"
                                    Click="SetReminder_Click"
                                    Content="Set reminder"
                                    Style="{StaticResource AccentButtonStyle}" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button
                    x:Name="NewButton"
                    AutomationProperties.AutomationId="NewNoteButton"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="New_Click"
                    Style="{StaticResource ToolButton}"
                    ToolTipService.ToolTip="New note">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="13" Glyph="&#xE710;" />
                        <TextBlock x:Name="NewText" FontSize="13" Text="New" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Two-pane: notes list + editor -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ListColumn" Width="288" />
                <ColumnDefinition x:Name="EditorColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Notes list -->
            <Border
                x:Name="ListPanel"
                Grid.Column="0"
                Margin="8,0,0,8"
                Background="{ThemeResource AppSurfaceBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Padding="8,8,8,4" Spacing="6">
                        <AutoSuggestBox
                            x:Name="SearchBox"
                            AutomationProperties.AutomationId="NotesSearch"
                            PlaceholderText="Search notes…"
                            QueryIcon="Find"
                            TextChanged="SearchBox_TextChanged" />
                        <ComboBox
                            x:Name="TagFilter"
                            HorizontalAlignment="Stretch"
                            AutomationProperties.AutomationId="TagFilter"
                            PlaceholderText="Filter by tag"
                            SelectionChanged="TagFilter_SelectionChanged" />
                    </StackPanel>
                    <ListView
                        x:Name="NotesList"
                        Grid.Row="1"
                        Padding="6"
                    AutomationProperties.AutomationId="NotesList"
                    ItemsSource="{x:Bind Vm.Notes}"
                    SelectedItem="{x:Bind Vm.Selected, Mode=TwoWay}"
                    SelectionChanged="NotesList_SelectionChanged"
                    SelectionMode="Single">
                    <ListView.Resources>
                        <!-- Kill the built-in (square) item fills; we draw our own rounded ones. -->
                        <SolidColorBrush x:Key="ListViewItemBackground" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="Transparent" />
                    </ListView.Resources>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Margin" Value="0,1" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:NoteListItemViewModel">
                            <Grid PointerEntered="Item_PointerEntered" PointerExited="Item_PointerExited">
                                <!-- selection layer (rounded) -->
                                <Border CornerRadius="12" Background="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource SelBrush}}" />
                                <!-- hover layer (rounded) -->
                                <Border CornerRadius="12" Background="{ThemeResource SubtleFillColorSecondaryBrush}" Opacity="0" />
                                <Grid Padding="10,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            Grid.Column="0"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{ThemeResource AppTextSecondaryBrush}"
                                            Glyph="&#xE718;"
                                            Visibility="{x:Bind Pinned, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                        <!-- List rows always use the theme's default text color — the note's
                                             custom title color shows only in the editor pane (owner request). -->
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource AppTextPrimaryBrush}"
                                            Text="{x:Bind DisplayTitle, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                        <FontIcon
                                            Grid.Column="2"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="#F59E0B"
                                            Glyph="&#xE735;"
                                            Visibility="{x:Bind Favorite, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource AppTextSecondaryBrush}"
                                        MaxLines="1"
                                        Text="{x:Bind Snippet, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap" />
                                </StackPanel>

                                <Button
                                    Grid.Column="1"
                                    Width="32"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Note actions"
                                    Style="{StaticResource ToolButton}"
                                    ToolTipService.ToolTip="Actions (pin, favorite, duplicate, delete)">
                                    <FontIcon FontSize="14" Glyph="&#xE712;" />
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Click="Pin_Click" Text="Pin / Unpin">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE718;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Click="Favorite_Click" Text="Favorite / Unfavorite">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE734;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Click="Duplicate_Click" Text="Duplicate">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Click="ConvertToTask_Click" Text="Convert to task">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8FD;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutItem Click="Archive_Click" Text="Archive">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7B8;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Click="Delete_Click" Text="Delete">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                </Grid>
            </Border>

            <!-- Editor -->
            <ScrollViewer x:Name="EditorScroll" Grid.Column="1" HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
                <Grid MaxWidth="900" Padding="32,4,32,48" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox
                        x:Name="TitleBox"
                        Grid.Row="0"
                        AutomationProperties.AutomationId="EditorTitle"
                        AutomationProperties.Name="Note title"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="30"
                        FontWeight="SemiBold"
                        PlaceholderText="Untitled"
                        Text="{x:Bind Vm.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextChanged="OnContentChanged" />

                    <!-- Tags for the current note: chips + add. -->
                    <StackPanel
                        Grid.Row="1"
                        Margin="0,4,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">
                        <ItemsControl ItemsSource="{x:Bind Vm.CurrentNoteTags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TagViewModel">
                                    <Border Padding="8,2" Background="{ThemeResource AppHoverBrush}" CornerRadius="10">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{x:Bind ColorHex, Converter={StaticResource HexToBrush}}" />
                                            <TextBlock VerticalAlignment="Center" FontSize="12" Text="{x:Bind Name}" />
                                            <Button
                                                MinWidth="0"
                                                Padding="2"
                                                AutomationProperties.Name="Remove tag"
                                                Click="RemoveTag_Click"
                                                Style="{StaticResource ToolButton}"
                                                Tag="{x:Bind Id}"
                                                ToolTipService.ToolTip="Remove tag">
                                                <FontIcon FontSize="10" Glyph="&#xE711;" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button
                            x:Name="AddTagButton"
                            AutomationProperties.AutomationId="AddTagButton"
                            Style="{StaticResource ToolButton}"
                            ToolTipService.ToolTip="Add a tag">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon FontSize="11" Glyph="&#xE710;" />
                                <TextBlock FontSize="12" Text="Tag" />
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout>
                                    <StackPanel Width="200" Spacing="8">
                                        <TextBlock FontWeight="SemiBold" Text="Add tag" />
                                        <TextBox x:Name="NewTagBox" AutomationProperties.AutomationId="NewTagBox" PlaceholderText="Tag name" />
                                        <Button
                                            HorizontalAlignment="Right"
                                            AutomationProperties.AutomationId="ConfirmAddTag"
                                            Click="AddTag_Click"
                                            Content="Add"
                                            Style="{StaticResource AccentButtonStyle}" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <TextBlock
                            x:Name="DictationStatus"
                            VerticalAlignment="Center"
                            AutomationProperties.AutomationId="DictationStatus"
                            FontSize="12"
                            Foreground="{ThemeResource AppTextSecondaryBrush}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,8,0,8">
                        <!-- Collapsed (compact): one button → all tools in a dropdown. -->
                        <Button
                            x:Name="ToolbarMoreButton"
                            HorizontalAlignment="Left"
                            AutomationProperties.AutomationId="EditorToolsButton"
                            AutomationProperties.Name="Formatting tools"
                            Style="{StaticResource ToolButton}"
                            ToolTipService.ToolTip="Formatting tools"
                            Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE712;" />
                                <TextBlock FontSize="13" Text="Tools" />
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                                        <ContentControl
                                            x:Name="ToolbarFlyoutHost"
                                            Width="300"
                                            HorizontalContentAlignment="Stretch" />
                                    </ScrollViewer>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <!-- Full (wide): inline toolbar. The WrapPanel instance moves between
                             this host and the flyout host above as the window resizes. -->
                        <ContentControl x:Name="ToolbarHost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                            <controls:WrapPanel
                                x:Name="EditorToolbar"
                                HorizontalSpacing="2"
                                VerticalSpacing="6">
                        <ComboBox
                            x:Name="FontFamilyCombo"
                            MinWidth="112"
                            AutomationProperties.AutomationId="FontFamilyCombo"
                            CornerRadius="8"
                            SelectionChanged="FontFamily_Changed"
                            ToolTipService.ToolTip="Font" />
                        <ComboBox
                            x:Name="FontSizeCombo"
                            MinWidth="72"
                            Margin="2,0,0,0"
                            AutomationProperties.AutomationId="FontSizeCombo"
                            CornerRadius="8"
                            IsEditable="True"
                            SelectionChanged="FontSize_Changed"
                            TextSubmitted="FontSize_Submitted"
                            ToolTipService.ToolTip="Font size" />
                        <Button
                            x:Name="ColorButton"
                            Margin="2,0,0,0"
                            AllowFocusOnInteraction="False"
                            AutomationProperties.AutomationId="ColorButton"
                            Style="{StaticResource ToolButton}"
                            ToolTipService.ToolTip="Text color">
                            <StackPanel Spacing="1">
                                <TextBlock HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold" Text="A" />
                                <Rectangle x:Name="ColorBar" Width="16" Height="3" Fill="{ThemeResource AppAccentBrush}" RadiusX="1" RadiusY="1" />
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout
                                    Closed="ColorFlyout_Closed"
                                    Opening="ColorFlyout_Opening"
                                    Placement="RightEdgeAlignedTop"
                                    ShouldConstrainToRootBounds="False">
                                    <StackPanel Width="236" Spacing="8">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AppTextSecondaryBrush}" Text="QUICK COLORS (instant)" />
                                        <GridView x:Name="SwatchGrid" IsItemClickEnabled="True" ItemClick="Color_Click" SelectionMode="None">
                                            <GridView.ItemContainerStyle>
                                                <Style TargetType="GridViewItem">
                                                    <Setter Property="Margin" Value="3" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="MinWidth" Value="0" />
                                                    <Setter Property="MinHeight" Value="0" />
                                                </Style>
                                            </GridView.ItemContainerStyle>
                                        </GridView>
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AppTextSecondaryBrush}" Text="PICK ANY COLOR" />
                                        <ColorPicker
                                            x:Name="CustomColorPicker"
                                            Width="212"
                                            Height="248"
                                            AutomationProperties.AutomationId="CustomColorPicker"
                                            ColorChanged="CustomColor_ColorChanged"
                                            ColorSpectrumShape="Box"
                                            IsAlphaEnabled="False"
                                            IsAlphaSliderVisible="False"
                                            IsColorChannelTextInputVisible="False"
                                            IsColorSliderVisible="True"
                                            IsHexInputVisible="True" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <Rectangle Width="1" Height="20" Margin="4,0" Fill="{ThemeResource AppBorderBrush}" />

                        <ToggleButton x:Name="BoldToggle" AutomationProperties.AutomationId="BoldButton" Click="Bold_Click" Style="{StaticResource ToolToggle}" ToolTipService.ToolTip="Bold (Ctrl+B)">
                            <FontIcon FontSize="15" Glyph="&#xE8DD;" />
                        </ToggleButton>
                        <ToggleButton x:Name="ItalicToggle" AutomationProperties.AutomationId="ItalicButton" Click="Italic_Click" Style="{StaticResource ToolToggle}" ToolTipService.ToolTip="Italic (Ctrl+I)">
                            <FontIcon FontSize="15" Glyph="&#xE8DB;" />
                        </ToggleButton>
                        <ToggleButton x:Name="UnderlineToggle" AutomationProperties.AutomationId="UnderlineButton" Click="Underline_Click" Style="{StaticResource ToolToggle}" ToolTipService.ToolTip="Underline (Ctrl+U)">
                            <FontIcon FontSize="15" Glyph="&#xE8DC;" />
                        </ToggleButton>

                        <Rectangle Width="1" Height="20" Margin="4,0" Fill="{ThemeResource AppBorderBrush}" />

                        <Button AutomationProperties.AutomationId="H1Button" Click="H1_Click" Content="H1" Style="{StaticResource ToolButton}" ToolTipService.ToolTip="Heading 1" />
                        <Button Click="H2_Click" Content="H2" Style="{StaticResource ToolButton}" ToolTipService.ToolTip="Heading 2" />
                        <Button Click="H3_Click" Content="H3" Style="{StaticResource ToolButton}" ToolTipService.ToolTip="Heading 3" />
                        <Button Click="Body_Click" Content="Body" Style="{StaticResource ToolButton}" ToolTipService.ToolTip="Body text" />

                        <Rectangle Width="1" Height="20" Margin="4,0" Fill="{ThemeResource AppBorderBrush}" />

                        <ToggleButton x:Name="BulletToggle" AutomationProperties.AutomationId="BulletButton" Click="Bullets_Click" Style="{StaticResource ToolToggle}" ToolTipService.ToolTip="Bulleted list">
                            <FontIcon FontSize="15" Glyph="&#xE8FD;" />
                        </ToggleButton>
                        <ToggleButton x:Name="NumberToggle" AutomationProperties.AutomationId="NumberButton" Click="Numbered_Click" Content="1." FontWeight="SemiBold" Style="{StaticResource ToolToggle}" ToolTipService.ToolTip="Numbered list" />
                        <Button x:Name="CircleButton" AutomationProperties.AutomationId="AddChecklistTool" Click="CircleList_Click" Style="{StaticResource ToolButton}" ToolTipService.ToolTip="Circle list (starts at the caret)">
                            <Ellipse Width="15" Height="15" Stroke="{ThemeResource AppTextPrimaryBrush}" StrokeThickness="1.5" />
                        </Button>
                        <Button AutomationProperties.AutomationId="AddMarkdownTool" Click="InsertCodeBlock_Click" Style="{StaticResource ToolButton}" ToolTipService.ToolTip="Insert a code block at the caret">
                            <TextBlock FontFamily="Consolas" FontSize="15" FontWeight="SemiBold" Text="{}{}" />
                        </Button>

                        <Rectangle Width="1" Height="20" Margin="4,0" Fill="{ThemeResource AppBorderBrush}" />

                        <ToggleButton x:Name="MicButton" AutomationProperties.AutomationId="MicButton" Click="Mic_Click" Style="{StaticResource ToolToggle}" ToolTipService.ToolTip="Dictate (speech to text)">
                            <FontIcon FontSize="15" Glyph="&#xE720;" />
                        </ToggleButton>

                        <Rectangle Width="1" Height="20" Margin="4,0" Fill="{ThemeResource AppBorderBrush}" />

                        <Button x:Name="AttachButton" AutomationProperties.AutomationId="AttachButton" Click="Attach_Click" Style="{StaticResource ToolButton}" ToolTipService.ToolTip="Attach image">
                            <FontIcon FontSize="15" Glyph="&#xE723;" />
                        </Button>
                        <Button x:Name="PasteImageButton" AutomationProperties.AutomationId="PasteImageButton" Click="PasteImage_Click" Style="{StaticResource ToolButton}" ToolTipService.ToolTip="Paste image from clipboard">
                            <FontIcon FontSize="15" Glyph="&#xE77F;" />
                        </Button>
                            </controls:WrapPanel>
                        </ContentControl>
                    </Grid>

                    <!-- Editor: rounded surface "card". A SOLID background is required —
                         WinUI gives a transparent text control a white (invisible) caret in light mode. -->
                    <Border
                        x:Name="EditorBorder"
                        Grid.Row="3"
                        MinHeight="84"
                        AllowDrop="True"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        DragOver="Editor_DragOver"
                        Drop="Editor_Drop"
                        Background="{ThemeResource AppSurfaceBrush}">
                        <StackPanel>
                        <RichEditBox
                            x:Name="EditorBox"
                            Padding="8,6"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollMode="Disabled"
                            AutomationProperties.AutomationId="EditorBody"
                            AutomationProperties.Name="Note body"
                            Background="{ThemeResource AppSurfaceBrush}"
                            BorderThickness="0"
                            CornerRadius="10"
                            FontSize="16"
                            Foreground="{ThemeResource AppTextPrimaryBrush}"
                            SelectionHighlightColorWhenNotFocused="{ThemeResource AppAccentBrush}"
                            GotFocus="Editor_GotFocus"
                            IsSpellCheckEnabled="True"
                            LostFocus="Editor_LostFocus"
                            PlaceholderText="Start writing…"
                            PreviewKeyDown="Editor_PreviewKeyDown"
                            SelectionChanged="Editor_SelectionChanged"
                            TextChanged="OnContentChanged">
                            <RichEditBox.Resources>
                                <!-- Solid surface fill in every state → caret derives a visible (dark-in-light) color. -->
                                <SolidColorBrush x:Key="TextControlBackground" Color="{ThemeResource AppSurfaceColor}" />
                                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{ThemeResource AppSurfaceColor}" />
                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{ThemeResource AppSurfaceColor}" />
                                <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                <SolidColorBrush x:Key="TextControlForeground" Color="{ThemeResource AppTextPrimaryColor}" />
                                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{ThemeResource AppTextPrimaryColor}" />
                                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{ThemeResource AppTextPrimaryColor}" />
                            </RichEditBox.Resources>
                        </RichEditBox>

                            <!-- Markdown composer ({} tool): type md here, Preview renders it into the
                                 note at the caret and closes the box. No formatting toolbar — md only. -->
                            <Border
                                x:Name="MdComposer"
                                Margin="6,4"
                                Padding="10"
                                Background="{ThemeResource AppHoverBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Visibility="Collapsed">
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AppTextSecondaryBrush}" Text="Markdown" />
                                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="6">
                                            <Button AutomationProperties.AutomationId="MdRenderButton" Click="MdRender_Click" Content="Preview" Style="{StaticResource AccentButtonStyle}" />
                                            <Button AutomationProperties.AutomationId="MdCancelButton" Click="MdCancel_Click" Content="Cancel" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBox
                                        x:Name="MdComposerBox"
                                        MinHeight="90"
                                        AcceptsReturn="True"
                                        AutomationProperties.AutomationId="MdComposerBox"
                                        FontFamily="Consolas"
                                        FontSize="14"
                                        IsSpellCheckEnabled="False"
                                        PlaceholderText="# Heading, **bold**, *italic*, `code`, or ```fenced``` blocks…"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!-- Checklist lives INSIDE the note box (Apple-style); add via the toolbar circle. -->
                            <ItemsControl Margin="6,0,6,6" ItemsSource="{x:Bind Vm.Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ChecklistItemViewModel">
                                        <Grid Padding="2,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" MinWidth="0" AutomationProperties.Name="Done" IsChecked="{x:Bind IsDone, Mode=TwoWay}" />
                                            <TextBox Grid.Column="1" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" FontSize="15" PlaceholderText="List item" Text="{x:Bind Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="2" Click="DeleteItem_Click" Style="{StaticResource ToolButton}" ToolTipService.ToolTip="Remove">
                                                <FontIcon FontSize="13" Glyph="&#xE711;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Attached images (attach / paste / drag-drop). -->
                            <ItemsControl Margin="6,0,6,8" ItemsSource="{x:Bind Attachments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:WrapPanel HorizontalSpacing="8" VerticalSpacing="8" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:AttachmentThumbViewModel">
                                        <Grid Width="120" Height="90">
                                            <Border BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1" CornerRadius="8">
                                                <Image Source="{x:Bind Image}" Stretch="UniformToFill" />
                                            </Border>
                                            <Button
                                                Margin="2"
                                                Padding="2"
                                                MinWidth="0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                AutomationProperties.Name="Remove attachment"
                                                Click="RemoveAttachment_Click"
                                                Style="{StaticResource ToolButton}"
                                                Tag="{x:Bind Id}"
                                                ToolTipService.ToolTip="Remove">
                                                <FontIcon FontSize="10" Glyph="&#xE711;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
