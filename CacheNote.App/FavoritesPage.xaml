<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CacheNote_App.FavoritesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:CacheNote_App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:CacheNote.Core.ViewModels"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="RowButton" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </Page.Resources>

    <Grid Padding="20,12,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Button
                HorizontalAlignment="Left"
                Padding="10,6"
                AutomationProperties.AutomationId="BackToHome"
                AutomationProperties.Name="Back to home"
                Background="Transparent"
                BorderThickness="0"
                Click="Back_Click"
                ToolTipService.ToolTip="Home">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE72B;" />
                    <TextBlock Text="Home" />
                </StackPanel>
            </Button>
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <FontIcon FontSize="18" Foreground="#DC2626" Glyph="&#xE735;" />
                <TextBlock
                    AutomationProperties.AutomationId="FavoritesTitle"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextPrimaryBrush}"
                    Text="Favorites" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel
                MaxWidth="820"
                HorizontalAlignment="Center"
                Spacing="10">
                <TextBlock
                    x:Name="EmptyHint"
                    Margin="4,20,0,0"
                    Foreground="{ThemeResource AppTextSecondaryBrush}"
                    Text="No favorites or pinned notes yet. Star or pin a note to see it here."
                    Visibility="Collapsed" />
                <ItemsRepeater x:Name="FavoritesList" AutomationProperties.AutomationId="FavoritesList" ItemsSource="{x:Bind Vm.Items}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:NoteListItemViewModel">
                            <Button
                                AutomationProperties.Name="Open note"
                                Click="Open_Click"
                                Style="{StaticResource RowButton}"
                                Tag="{x:Bind Id}">
                                <Border
                                    Padding="14,10"
                                    Background="{ThemeResource AppSurfaceBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource AppTextPrimaryBrush}"
                                                Text="{x:Bind DisplayTitle}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{ThemeResource AppTextSecondaryBrush}"
                                                MaxLines="1"
                                                Text="{x:Bind Snippet}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <FontIcon
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            Foreground="{ThemeResource AppTextSecondaryBrush}"
                                            Glyph="&#xE718;"
                                            Visibility="{x:Bind Pinned, Converter={StaticResource BoolToVis}}" />
                                        <FontIcon
                                            Grid.Column="2"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            Foreground="#F59E0B"
                                            Glyph="&#xE735;"
                                            Visibility="{x:Bind Favorite, Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
