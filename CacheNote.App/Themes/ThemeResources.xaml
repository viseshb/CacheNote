<?xml version="1.0" encoding="utf-8" ?>
<!--
    CacheNote theme tokens. Colors come straight from the PRD. Brushes are
    resolved per-theme via ThemeDictionaries so Light/Dark/HighContrast switch
    automatically with the system or the in-app toggle. Surfaces are layered
    over Mica, so cards use the opaque Surface brush while page roots stay
    transparent to let the material show through.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!-- LIGHT -->
        <ResourceDictionary x:Key="Light">
            <Color x:Key="AppBackgroundColor">#FAFAF8</Color>
            <Color x:Key="AppSurfaceColor">#FFFFFF</Color>
            <Color x:Key="AppBorderColor">#A1A1AA</Color>
            <Color x:Key="AppTextPrimaryColor">#18181B</Color>
            <Color x:Key="AppTextSecondaryColor">#71717A</Color>
            <Color x:Key="AppAccentColor">#2563EB</Color>
            <Color x:Key="AppHoverColor">#18000000</Color>
            <Color x:Key="AppPressedColor">#2B000000</Color>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
            <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorderColor}" />
            <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="{StaticResource AppTextPrimaryColor}" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="{StaticResource AppTextSecondaryColor}" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="{StaticResource AppAccentColor}" />
            <SolidColorBrush x:Key="AppHoverBrush" Color="{StaticResource AppHoverColor}" />
            <SolidColorBrush x:Key="AppPressedBrush" Color="{StaticResource AppPressedColor}" />

            <!-- Round every framework control (buttons, combos, list selection, text boxes…). -->
            <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
            <CornerRadius x:Key="OverlayCornerRadius">10</CornerRadius>
        </ResourceDictionary>

        <!-- DARK -->
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="AppBackgroundColor">#121212</Color>
            <Color x:Key="AppSurfaceColor">#1E1E1E</Color>
            <Color x:Key="AppBorderColor">#2A2A2A</Color>
            <Color x:Key="AppTextPrimaryColor">#F5F5F5</Color>
            <Color x:Key="AppTextSecondaryColor">#A1A1AA</Color>
            <Color x:Key="AppAccentColor">#60A5FA</Color>
            <Color x:Key="AppHoverColor">#22FFFFFF</Color>
            <Color x:Key="AppPressedColor">#38FFFFFF</Color>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
            <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorderColor}" />
            <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="{StaticResource AppTextPrimaryColor}" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="{StaticResource AppTextSecondaryColor}" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="{StaticResource AppAccentColor}" />
            <SolidColorBrush x:Key="AppHoverBrush" Color="{StaticResource AppHoverColor}" />
            <SolidColorBrush x:Key="AppPressedBrush" Color="{StaticResource AppPressedColor}" />

            <!-- Round every framework control (buttons, combos, list selection, text boxes…). -->
            <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
            <CornerRadius x:Key="OverlayCornerRadius">10</CornerRadius>
        </ResourceDictionary>

        <!-- HIGH CONTRAST (system colors so the OS HC themes drive it) -->
        <ResourceDictionary x:Key="HighContrast">
            <!-- Color fallbacks so {ThemeResource *Color} keys resolve in HC too. -->
            <Color x:Key="AppTextPrimaryColor">#FFFFFF</Color>
            <Color x:Key="AppSurfaceColor">#000000</Color>
            <Color x:Key="AppBorderColor">#FFFFFF</Color>
            <Color x:Key="AppAccentColor">#60A5FA</Color>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="{ThemeResource SystemColorWindowColor}" />
            <SolidColorBrush x:Key="AppBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AppHoverBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="AppPressedBrush" Color="{ThemeResource SystemColorHighlightColor}" />

            <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
            <CornerRadius x:Key="OverlayCornerRadius">10</CornerRadius>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
