<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CacheNote_App.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CacheNote_App.Controls"
    xmlns:conv="using:CacheNote_App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:CacheNote.Core.ViewModels"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:HexToBrushConverter x:Key="HexToBrush" />
        <Style x:Key="GhostIcon" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Foreground" Value="{ThemeResource AppTextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource AppHoverBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource AppPressedBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Padding="20,12,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Button
                HorizontalAlignment="Left"
                Padding="10,6"
                AutomationProperties.AutomationId="BackToHome"
                AutomationProperties.Name="Back to home"
                Background="Transparent"
                BorderThickness="0"
                Click="Back_Click"
                ToolTipService.ToolTip="Home">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE72B;" />
                    <TextBlock Text="Home" />
                </StackPanel>
            </Button>
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <FontIcon FontSize="18" Foreground="{ThemeResource AppAccentBrush}" Glyph="&#xE8FD;" />
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextPrimaryBrush}"
                    Text="Tasks" />
            </StackPanel>
        </Grid>

        <!-- Centered scroll area: create row + list (centered on wide, full width when narrow) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel
                MaxWidth="820"
                HorizontalAlignment="Center"
                Spacing="14">

                <!-- Create row -->
                <Border
                    Padding="12"
                    Background="{ThemeResource AppSurfaceBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <controls:WrapPanel HorizontalSpacing="10" VerticalSpacing="10">
                        <TextBox
                            x:Name="TitleBox"
                            Width="240"
                            AutomationProperties.AutomationId="TaskTitle"
                            PlaceholderText="New task…" />
                        <CalendarDatePicker
                            x:Name="DueDate"
                            MinWidth="150"
                            AutomationProperties.AutomationId="TaskDueDate"
                            PlaceholderText="Due date (optional)" />
                        <TimePicker
                            x:Name="DueTime"
                            AutomationProperties.AutomationId="TaskDueTime"
                            ClockIdentifier="12HourClock" />
                        <ComboBox
                            x:Name="PriorityCombo"
                            MinWidth="120"
                            AutomationProperties.AutomationId="TaskPriority"
                            SelectedIndex="1">
                            <ComboBoxItem Content="Low" />
                            <ComboBoxItem Content="Medium" />
                            <ComboBoxItem Content="High" />
                        </ComboBox>
                        <Button
                            x:Name="AddButton"
                            AutomationProperties.AutomationId="AddTask"
                            Click="Add_Click"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE710;" />
                                <TextBlock Text="Add task" />
                            </StackPanel>
                        </Button>
                    </controls:WrapPanel>
                </Border>

                <!-- List -->
                <TextBlock
                    x:Name="EmptyHint"
                    Margin="4,8,0,0"
                    Foreground="{ThemeResource AppTextSecondaryBrush}"
                    Text="No tasks yet. Add one above."
                    Visibility="Collapsed" />
                <ItemsRepeater x:Name="TasksList" AutomationProperties.AutomationId="TasksList" ItemsSource="{x:Bind Vm.Tasks}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskItemViewModel">
                            <Border
                                Padding="12,8"
                                Background="{ThemeResource AppSurfaceBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox
                                        Grid.Column="0"
                                        MinWidth="0"
                                        VerticalAlignment="Center"
                                        AutomationProperties.Name="Complete task"
                                        Click="Complete_Click"
                                        IsChecked="{x:Bind IsCompleted}"
                                        Tag="{x:Bind Id}" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource AppTextPrimaryBrush}"
                                            Opacity="{x:Bind TitleOpacity}"
                                            Text="{x:Bind Title}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource AppTextSecondaryBrush}"
                                            Text="{x:Bind DueText}" />
                                    </StackPanel>

                                    <Border
                                        Grid.Column="2"
                                        Padding="8,3"
                                        VerticalAlignment="Center"
                                        Background="{x:Bind PriorityColor, Converter={StaticResource HexToBrush}}"
                                        CornerRadius="8">
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{x:Bind PriorityText}" />
                                    </Border>

                                    <Button
                                        Grid.Column="3"
                                        AutomationProperties.Name="Delete task"
                                        Click="Delete_Click"
                                        Style="{StaticResource GhostIcon}"
                                        Tag="{x:Bind Id}"
                                        ToolTipService.ToolTip="Delete">
                                        <FontIcon FontSize="15" Glyph="&#xE74D;" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
