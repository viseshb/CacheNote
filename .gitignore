# CacheNote runtime data (must never be committed). ANCHORED to repo root with a leading "/"
# so they do NOT also match source folders like CacheNote.Core/Data — git is case-insensitive
# on Windows, so an unanchored "data/" was excluding the entire Core/Data source tree.
/data/
/attachments/
/logs/
/config/
.portable

# Node (semantic-release tooling only — this is a .NET repo)
node_modules/
package-lock.json

# IDE
.vs/
*.suo
