<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="StickyDesk_App.ComingSoonPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:StickyDesk_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid Padding="20,12,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button
            Grid.Row="0"
            Padding="10,6"
            AutomationProperties.AutomationId="BackToHome"
            AutomationProperties.Name="Back to home"
            Background="Transparent"
            BorderThickness="0"
            Click="Back_Click">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon FontSize="14" Glyph="&#xE72B;" />
                <TextBlock Text="Home" />
            </StackPanel>
        </Button>

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MaxWidth="420"
            Spacing="10">
            <TextBlock
                x:Name="TitleText"
                HorizontalAlignment="Center"
                FontSize="28"
                FontWeight="SemiBold"
                Foreground="{ThemeResource AppTextPrimaryBrush}" />
            <Border
                Padding="10,4"
                HorizontalAlignment="Center"
                Background="{ThemeResource AppAccentBrush}"
                CornerRadius="10">
                <TextBlock
                    x:Name="MilestoneText"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="White" />
            </Border>
            <TextBlock
                x:Name="SubtitleText"
                HorizontalAlignment="Center"
                FontSize="14"
                Foreground="{ThemeResource AppTextSecondaryBrush}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Page>
