<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="StickyDesk_App.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:StickyDesk_App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource AppTextSecondaryBrush}" />
            <Setter Property="Margin" Value="2,0,0,2" />
        </Style>
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{ThemeResource AppTextPrimaryBrush}" />
        </Style>
    </Page.Resources>

    <Grid Padding="20,12,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Button
                HorizontalAlignment="Left"
                Padding="10,6"
                AutomationProperties.AutomationId="BackToHome"
                AutomationProperties.Name="Back to home"
                Background="Transparent"
                BorderThickness="0"
                Click="Back_Click"
                ToolTipService.ToolTip="Home">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="14" Glyph="&#xE72B;" />
                    <TextBlock Text="Home" />
                </StackPanel>
            </Button>
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <FontIcon FontSize="18" Foreground="{ThemeResource AppAccentBrush}" Glyph="&#xE713;" />
                <TextBlock
                    AutomationProperties.AutomationId="SettingsTitle"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AppTextPrimaryBrush}"
                    Text="Settings" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel
                MaxWidth="640"
                HorizontalAlignment="Center"
                Spacing="14">

                <!-- Appearance -->
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource SectionTitle}" Text="APPEARANCE" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel Spacing="14">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Style="{StaticResource RowLabel}"
                                    Text="Theme"
                                    TextTrimming="CharacterEllipsis" />
                                <ComboBox
                                    x:Name="ThemeCombo"
                                    Grid.Column="1"
                                    MinWidth="150"
                                    AutomationProperties.AutomationId="ThemeSetting"
                                    SelectionChanged="Theme_Changed">
                                    <ComboBoxItem Content="Use system" />
                                    <ComboBoxItem Content="Light" />
                                    <ComboBoxItem Content="Dark" />
                                </ComboBox>
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Style="{StaticResource RowLabel}"
                                    Text="Editor font size"
                                    TextTrimming="CharacterEllipsis" />
                                <ComboBox
                                    x:Name="FontSizeCombo"
                                    Grid.Column="1"
                                    MinWidth="150"
                                    AutomationProperties.AutomationId="FontSizeSetting"
                                    SelectionChanged="FontSize_Changed" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Behavior -->
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource SectionTitle}" Text="BEHAVIOR" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel Spacing="6">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Style="{StaticResource RowLabel}"
                                    Text="Launch at startup"
                                    TextTrimming="CharacterEllipsis" />
                                <ToggleSwitch
                                    x:Name="StartupToggle"
                                    Grid.Column="1"
                                    MinWidth="0"
                                    AutomationProperties.AutomationId="StartupToggle"
                                    Toggled="Startup_Toggled" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Style="{StaticResource RowLabel}"
                                    Text="Always on top"
                                    TextTrimming="CharacterEllipsis" />
                                <ToggleSwitch
                                    x:Name="AlwaysOnTopToggle"
                                    Grid.Column="1"
                                    MinWidth="0"
                                    AutomationProperties.AutomationId="AlwaysOnTopToggle"
                                    Toggled="AlwaysOnTop_Toggled" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Style="{StaticResource RowLabel}"
                                    Text="Pause notifications"
                                    TextTrimming="CharacterEllipsis" />
                                <ToggleSwitch
                                    x:Name="PauseToggle"
                                    Grid.Column="1"
                                    MinWidth="0"
                                    AutomationProperties.AutomationId="PauseToggle"
                                    Toggled="Pause_Toggled" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Window modes -->
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource SectionTitle}" Text="WINDOW" />
                    <Border Style="{StaticResource Card}">
                        <controls:WrapPanel HorizontalSpacing="8" VerticalSpacing="8">
                            <Button AutomationProperties.AutomationId="CompactButton" Click="Compact_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE73F;" />
                                    <TextBlock Text="Compact" />
                                </StackPanel>
                            </Button>
                            <Button AutomationProperties.AutomationId="DockLeftButton" Click="DockLeft_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE76B;" />
                                    <TextBlock Text="Dock left" />
                                </StackPanel>
                            </Button>
                            <Button AutomationProperties.AutomationId="DockRightButton" Click="DockRight_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE76C;" />
                                    <TextBlock Text="Dock right" />
                                </StackPanel>
                            </Button>
                            <Button AutomationProperties.AutomationId="RestoreButton" Click="Restore_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE73F;" />
                                    <TextBlock Text="Restore" />
                                </StackPanel>
                            </Button>
                        </controls:WrapPanel>
                    </Border>
                </StackPanel>

                <!-- Voice & AI keys -->
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource SectionTitle}" Text="VOICE &amp; AI" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel Spacing="10">
                            <TextBlock FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" Text="Keys are read from the .env file in the app folder. Edit that file and restart to change them." TextWrapping="Wrap" />

                            <!-- Live connectivity test -->
                            <controls:WrapPanel HorizontalSpacing="8" VerticalSpacing="8">
                                <Button
                                    x:Name="TestDeepgramBtn"
                                    AutomationProperties.AutomationId="TestDeepgramButton"
                                    Click="TestDeepgram_Click"
                                    Content="Test Deepgram" />
                                <Button
                                    x:Name="TestAssemblyBtn"
                                    AutomationProperties.AutomationId="TestAssemblyButton"
                                    Click="TestAssembly_Click"
                                    Content="Test AssemblyAI" />
                                <Button
                                    x:Name="TestAiBtn"
                                    AutomationProperties.AutomationId="TestAiButton"
                                    Click="TestAi_Click"
                                    Content="Test AI" />
                            </controls:WrapPanel>
                            <TextBlock
                                x:Name="ConnTestStatus"
                                AutomationProperties.AutomationId="ConnTestStatus"
                                FontSize="12"
                                Foreground="{ThemeResource AppTextSecondaryBrush}"
                                TextWrapping="Wrap" />

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Speech provider" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="SttProviderText" Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Deepgram key" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="DeepgramKeyText" Grid.Column="1" VerticalAlignment="Center" FontFamily="Consolas" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="AssemblyAI key" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="AssemblyKeyText" Grid.Column="1" VerticalAlignment="Center" FontFamily="Consolas" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="AI provider" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="AiProviderText" Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                            </Grid>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Gemini / Vertex key" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="GeminiKeyText" Grid.Column="1" VerticalAlignment="Center" FontFamily="Consolas" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Storage / portability -->
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource SectionTitle}" Text="STORAGE" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="13" Foreground="{ThemeResource AppTextPrimaryBrush}" Text="All your data lives in the app folder. Move the folder and everything moves with it." TextWrapping="Wrap" />
                            <TextBlock x:Name="RootPathText" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" IsTextSelectionEnabled="True" TextWrapping="Wrap" />
                            <TextBlock x:Name="PortableText" FontSize="12" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
