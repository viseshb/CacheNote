<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="StickyDesk_App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:StickyDesk_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="using:H.NotifyIcon"
    Title="StickyDesk"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.KeyboardAccelerators>
            <!-- In-window new note. Ctrl+F / Ctrl+P / Ctrl+D land with search & pin in M4. -->
            <KeyboardAccelerator
                Key="N"
                Invoked="NewNoteAccelerator_Invoked"
                Modifiers="Control" />
        </Grid.KeyboardAccelerators>
        <Grid.Resources>
            <!-- Flat icon button with a clear hover/press shade (title-bar actions). -->
            <Style x:Key="TitleBarButton" TargetType="Button">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid
                                x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource AppHoverBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource AppPressedBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding Content}" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TitleBar x:Name="AppTitleBar" Title="StickyDesk">
                <TitleBar.IconSource>
                    <ImageIconSource ImageSource="Assets/AppIcon.ico" />
                </TitleBar.IconSource>
            </TitleBar>
            <!-- Title-bar actions, overlaid at the right, clear of the system caption buttons. -->
            <StackPanel
                Margin="0,0,148,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="2">
                <!-- Check GitHub Releases for a newer build (M10). -->
                <Button
                    x:Name="UpdateButton"
                    AutomationProperties.AutomationId="UpdateButton"
                    AutomationProperties.Name="Check for updates"
                    Click="Update_Click"
                    Style="{StaticResource TitleBarButton}"
                    ToolTipService.ToolTip="Check for updates">
                    <FontIcon FontSize="15" Glyph="&#xE896;" />
                </Button>
                <!-- Theme toggle -->
                <Button
                    x:Name="ThemeToggleButton"
                    AutomationProperties.AutomationId="ThemeToggle"
                    AutomationProperties.Name="Toggle light or dark theme"
                    Click="ThemeToggle_Click"
                    Style="{StaticResource TitleBarButton}"
                    ToolTipService.ToolTip="Toggle light / dark theme">
                    <FontIcon x:Name="ThemeIcon" FontSize="16" Glyph="&#xE706;" />
                </Button>
            </StackPanel>
        </Grid>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" />

        <!-- System tray icon (renders nothing in-window). Left-click opens; right-click = menu. -->
        <tb:TaskbarIcon
            x:Name="TrayIcon"
            IconSource="/Assets/AppIcon.ico"
            ToolTipText="StickyDesk — click to open">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Click="Tray_Open" Text="Open StickyDesk">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8A7;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Click="Tray_NewNote" Text="New note">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE70F;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Click="Tray_NewTask" Text="New task">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8FD;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <ToggleMenuFlyoutItem x:Name="AlwaysOnTopItem" Click="Tray_ToggleAlwaysOnTop" Text="Always on top" />
                    <ToggleMenuFlyoutItem x:Name="PauseNotifyItem" Click="Tray_TogglePause" Text="Pause notifications" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Click="Tray_Settings" Text="Settings">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE713;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Click="Tray_Exit" Text="Exit">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE7E8;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>
    </Grid>
</Window>
